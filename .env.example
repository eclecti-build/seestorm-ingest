# SeeStorm Ingest Environment Variables
# Copy this file to .env and fill in values

# ─── Database (required) ─────────────────────────────────────────
# Neon Postgres connection string with PostGIS
# Get one at: https://console.neon.tech/ (free tier)
# Enable PostGIS: run "CREATE EXTENSION postgis;" on your database
DATABASE_URL=postgresql://user:password@ep-something-123456.us-east-2.aws.neon.tech/seestorm?sslmode=require

# ─── Polling ─────────────────────────────────────────────────────
# How often to poll NWS/SPC (Go duration format)
POLL_INTERVAL=30s

# ─── Snapshot Output ─────────────────────────────────────────────
# Where to write the active-events.json snapshot
# Local: ./snapshots (for dev)
# Fly.io: /data/snapshots (mounted volume)
SNAPSHOT_DIR=./snapshots

# ─── R2 Publishing (production) ──────────────────────────────────
# When set, snapshots are also uploaded to Cloudflare R2
# Leave empty for local-only development
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=seestorm-data

# ─── NWS Configuration ──────────────────────────────────────────
# NWS API requires a User-Agent with app name + contact
NWS_USER_AGENT=(seestorm.org, contact@seestorm.org)

# Target area for alert polling. Accepts a single USPS state code (e.g. "WI")
# or a comma-separated list. The NWS API returns one merged FeatureCollection
# regardless, so multi-state polling is one HTTP request.
# Default if unset: WI
# Great Lakes basin example: NWS_AREA=MN,WI,IL,IN,MI,OH,PA,NY,IA
NWS_AREA=WI

# ─── Fleet role (production) ─────────────────────────────────────
# Selects which phases of the poll cycle this process runs: "both"
# (default, local dev / single-node), "ingest" (region-scoped node: polls +
# writes DB, no publish), or "publish" (reads DB, writes R2 snapshots, no
# polling).
# REQUIRED on Fly: any process with FLY_APP_NAME set (every Fly app) that is
# missing MODE fails to boot rather than silently defaulting to "both" —
# exactly one Fly app may run MODE=publish; a second publisher multiplies R2
# history writes (see the 2026-05 history-amplification incident).
MODE=both

# ─── Atlas / Ent migrations ──────────────────────────────────────
# Local Postgres URL used by `atlas migrate diff` during schema development.
# Point at a disposable local Postgres (e.g. Docker) — NOT production.
# Example: postgres://postgres:postgres@localhost:5432/seestorm_dev?sslmode=disable
ATLAS_LOCAL_URL=
